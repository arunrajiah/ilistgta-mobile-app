# ──────────────────────────────────────────────────────────────────────────────
# iListGTA Mobile App — Environment Variables
# Copy this file to .env and fill in your values.
# All EXPO_PUBLIC_* vars are baked into the JS bundle at build time.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL and anon (publishable) key.
# Find these in Supabase → Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── API Base URL ──────────────────────────────────────────────────────────────
# The base URL of the deployed iListGTA web app.
# All API calls (/api/v1/listings, etc.) are made relative to this URL.
# For local development against the Next.js dev server, use http://localhost:3000
EXPO_PUBLIC_API_BASE_URL=https://ilistgta.iokode.com

# ── Google Maps ───────────────────────────────────────────────────────────────
# Required for the Map tab (react-native-maps with Google Maps).
# This key is injected into the native iOS/Android binary at build time via app.config.js.
# IMPORTANT: Restrict this key to your iOS bundle ID (com.ilistgta.app) and
# Android package name in the Google Cloud Console to prevent abuse.
#
# Leave blank to disable the Map tab gracefully — users see a helpful setup screen
# instead of a crash or blank map.
#
# The same key can also be configured in Admin → Mobile → API Keys (site_settings),
# which serves it via /api/mobile/config as a reference for the admin — but
# the NATIVE SDK always uses the key baked in at build time.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
