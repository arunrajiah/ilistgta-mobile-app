{
  "expo": {
    "name": "iListGTA",
    "slug": "ilistgta",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ilistgta",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 320,
      "resizeMode": "contain",
      "backgroundColor": "#2d7a2d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ilistgta.app",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "imageWidth": 320,
        "resizeMode": "contain",
        "backgroundColor": "#2d7a2d"
      },
      "config": {
        "googleMapsApiKey": ""
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2d7a2d"
      },
      "package": "com.ilistgta.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
